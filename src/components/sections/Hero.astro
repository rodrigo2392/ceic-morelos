---
import { site } from '../../data/site';
const UPLOADS = '/img/set';
const GRAIN =
  "data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22120%22 height=%22120%22><filter id=%22n%22><feTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%222%22/></filter><rect width=%22120%22 height=%22120%22 filter=%22url(%23n)%22/></svg>";
---

<section id="hero" data-theme="dark" style="position:relative;height:100vh;min-height:640px;width:100%;overflow:hidden;background:#0d0c0b">
  <div class="ceic-hero-media" style="position:absolute;inset:0;z-index:0;overflow:hidden">
    <video
      id="ceic-herovideo"
      muted
      playsinline
      preload="auto"
      poster={`${UPLOADS}/CEIC5-1024x576.jpg`}
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transform-origin:center center;animation:ceicKen 22s ease-out forwards"
    >
      <source src="/video/ceic-intro.webm" type="video/webm" />
      <source src="/video/ceic-intro.mp4" type="video/mp4" />
    </video>
  </div>
  <div style="position:absolute;inset:0;z-index:1;background:linear-gradient(180deg,rgba(13,12,11,.32) 0%,rgba(13,12,11,.08) 42%,rgba(13,12,11,.55) 100%)"></div>
  <div style="position:absolute;inset:0;z-index:1;background:radial-gradient(ellipse at 50% 46%,transparent 40%,rgba(0,0,0,.35) 100%)"></div>
  <div id="ceic-hero-veil" style="position:absolute;inset:0;z-index:3;opacity:0;transition:opacity 1.3s ease;background:linear-gradient(180deg,rgba(13,12,11,.72) 0%,rgba(13,12,11,.5) 45%,rgba(13,12,11,.88) 100%)"></div>
  <div style={`position:absolute;inset:0;z-index:2;opacity:.14;pointer-events:none;background-image:url('${GRAIN}');background-size:200px;mix-blend-mode:overlay`}></div>

  <!-- letterbox -->
  <div id="ceic-lbtop" style="position:absolute;top:0;left:0;right:0;height:clamp(88px,13vh,150px);background:#0a0908;z-index:5;transition:height 1.4s cubic-bezier(.7,0,.2,1)"></div>
  <div id="ceic-lbbot" style="position:absolute;bottom:0;left:0;right:0;height:clamp(88px,13vh,150px);background:#0a0908;z-index:5;transition:height 1.4s cubic-bezier(.7,0,.2,1)"></div>

  <!-- frame corners -->
  <div style="position:absolute;top:calc(var(--ceic-bar-h) + 26px);left:34px;width:26px;height:26px;border-left:1px solid rgba(244,239,230,.45);border-top:1px solid rgba(244,239,230,.45);z-index:6"></div>
  <div style="position:absolute;top:calc(var(--ceic-bar-h) + 26px);right:34px;width:26px;height:26px;border-right:1px solid rgba(244,239,230,.45);border-top:1px solid rgba(244,239,230,.45);z-index:6"></div>
  <div style="position:absolute;bottom:calc(var(--ceic-bar-h) + 26px);left:34px;width:26px;height:26px;border-left:1px solid rgba(244,239,230,.45);border-bottom:1px solid rgba(244,239,230,.45);z-index:6"></div>
  <div style="position:absolute;bottom:calc(var(--ceic-bar-h) + 26px);right:34px;width:26px;height:26px;border-right:1px solid rgba(244,239,230,.45);border-bottom:1px solid rgba(244,239,230,.45);z-index:6"></div>
  <div class="ceic-hero-rec" style="position:absolute;top:calc(var(--ceic-bar-h) + 24px);left:50%;transform:translateX(-50%);white-space:nowrap;font-family:'Space Mono',monospace;font-size:15px;letter-spacing:.4em;color:rgba(244,239,230,.5);z-index:6">● REC · CEIC 24 FPS</div>

  <div id="ceic-herocontent" style="position:absolute;inset:0;z-index:6;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;padding:0 24px">
    <div data-hero="1" style="opacity:0;transform:translateY(20px);filter:blur(14px);transition:all 1s cubic-bezier(.2,.7,.2,1)">
      <div style="display:inline-flex;align-items:center;gap:14px;font-family:'Space Mono',monospace;font-size:clamp(13px,1.5vw,17px);letter-spacing:.32em;text-transform:uppercase;color:#d8a24a;margin-bottom:26px">
        <span style="width:34px;height:1px;background:#d8a24a"></span>
        Maestros premiados — Ariel · selección Cannes
        <span style="width:34px;height:1px;background:#d8a24a"></span>
      </div>
    </div>
    <h1 data-hero="2" style="opacity:0;transform:translateY(24px);filter:blur(16px);transition:all 1.1s cubic-bezier(.2,.7,.2,1) .15s;font-family:'Bodoni Moda',serif;font-weight:500;font-optical-sizing:none;font-size:clamp(46px,9vw,150px);line-height:.92;letter-spacing:-.01em;margin:0;text-shadow:0 2px 24px rgba(0,0,0,.75),0 12px 60px rgba(0,0,0,.6)">Aquí se forman<br /><em style="font-style:italic;font-weight:600;color:#d8a24a">cineastas</em> de verdad</h1>
    <p data-hero="3" style="opacity:0;transform:translateY(20px);filter:blur(10px);transition:all 1s cubic-bezier(.2,.7,.2,1) .32s;max-width:560px;font-size:clamp(15px,1.5vw,19px);line-height:1.6;color:rgba(244,239,230,.92);margin:30px 0 0;font-weight:300;text-shadow:0 2px 16px rgba(0,0,0,.7)">Escuela de cine y casa productora en Cuernavaca. Del guion a la pantalla, con quienes ya cuentan historias que el mundo ve.</p>
    <div data-hero="4" style="opacity:0;transform:translateY(20px);transition:all 1s cubic-bezier(.2,.7,.2,1) .5s;display:flex;flex-wrap:wrap;gap:16px;justify-content:center;margin-top:40px">
      <a href="#contacto" class="ceic-nav-cta" style="position:relative;overflow:hidden;font-family:'Space Mono',monospace;font-size:17px;letter-spacing:.18em;text-transform:uppercase;color:#0d0c0b;background:#d8a24a;padding:17px 34px;border-radius:2px;font-weight:700">Solicita informes</a>
      <a href={site.whatsapp.link} target="_blank" rel="noopener" class="ceic-btn-outline" style="font-family:'Space Mono',monospace;font-size:17px;letter-spacing:.18em;text-transform:uppercase;color:#f4efe6;border:1px solid rgba(244,239,230,.45);padding:17px 34px;border-radius:2px">WhatsApp directo</a>
    </div>
  </div>

  <a href="#" id="ceic-sound" aria-label="Sonido" style="position:absolute;bottom:calc(var(--ceic-bar-h) + 30px);right:34px;z-index:7;display:flex;align-items:center;gap:9px;font-family:'Space Mono',monospace;font-size:15px;letter-spacing:.22em;color:rgba(244,239,230,.8);border:1px solid rgba(244,239,230,.32);padding:9px 14px;border-radius:2px;background:rgba(10,9,8,.35);backdrop-filter:blur(4px)">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M4 9v6h4l5 4V5L8 9H4z"></path><path data-son-on style="display:none" d="M17 8a5 5 0 0 1 0 8"></path><path data-son-on style="display:none" d="M20 5a9 9 0 0 1 0 14"></path><path data-son-off style="display:inline" d="M17 9l5 6M22 9l-5 6"></path></svg>
    <span><span data-son-off style="display:inline">ACTIVAR SONIDO</span><span data-son-on style="display:none">SILENCIAR</span></span>
  </a>
  <div class="ceic-scrollcue" style="position:absolute;bottom:calc(var(--ceic-bar-h) + 28px);left:50%;transform:translateX(-50%);z-index:6;display:flex;flex-direction:column;align-items:center;gap:10px">
    <span style="font-family:'Space Mono',monospace;font-size:13.5px;letter-spacing:.34em;color:rgba(244,239,230,.6)">SCROLL</span>
    <div style="width:1px;height:44px;background:rgba(244,239,230,.25);position:relative;overflow:hidden"><div style="position:absolute;top:0;left:0;width:1px;height:14px;background:#d8a24a;animation:ceicScroll 1.8s ease-in-out infinite"></div></div>
  </div>
</section>
