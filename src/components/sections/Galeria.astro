---
import { galeria } from '../../data/galeria';
const stripe =
  'repeating-linear-gradient(135deg,#e3dccb,#e3dccb 8px,#d8d0bd 8px,#d8d0bd 16px)';
---

<section id="galeria" data-theme="light" style="background:#f4efe6;color:#1a1714;padding:clamp(80px,12vh,150px) clamp(24px,7vw,110px)">
  <div style="max-width:1300px;margin:0 auto">
    <div data-reveal style="display:flex;align-items:baseline;gap:20px;margin-bottom:18px">
      <span style="font-family:'Bodoni Moda',serif;font-size:clamp(40px,6vw,84px);font-weight:400;color:rgba(26,23,20,.14);line-height:.8">05</span>
      <span style="font-family:'Space Mono',monospace;font-size:18px;letter-spacing:.22em;text-transform:uppercase;color:#b07d2a">Detrás de cámara</span>
    </div>
    <div data-reveal style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:16px;margin-bottom:52px">
      <h2 style="font-family:'Bodoni Moda',serif;font-weight:400;font-size:clamp(32px,5vw,66px);line-height:1;margin:0">Vida en la escuela</h2>
      <span style="font-family:'Space Mono',monospace;font-size:16px;letter-spacing:.16em;color:#b07d2a;white-space:nowrap">⤢ Clic para ampliar</span>
    </div>
    <div class="ceic-gallery" style="display:grid;grid-template-columns:repeat(6,1fr);grid-auto-rows:clamp(180px,25vw,330px);gap:clamp(10px,1.4vw,18px)">
      {
        galeria.map((f, i) => (
          <figure
            data-reveal
            class="ceic-gal-item"
            data-gal-index={i}
            data-caption={f.caption ?? f.alt}
            tabindex="0"
            role="button"
            aria-label={`Ampliar: ${f.alt}`}
            style={`grid-column:span ${f.span};grid-row:span ${f.rowSpan ?? 1};position:relative;height:100%;overflow:hidden;margin:0;cursor:pointer;background:${stripe}`}
          >
            <img src={f.src} alt={f.alt} loading="lazy" class="ceic-gal-img" style="width:100%;height:100%;object-fit:cover" />
            <div data-fallback style="display:none;position:absolute;inset:0;align-items:center;justify-content:center;font-family:'Space Mono',monospace;font-size:15px;color:rgba(26,23,20,.4)">FOTO</div>
            <span class="ceic-gal-zoom" aria-hidden="true">⤢</span>
          </figure>
        ))
      }
    </div>
  </div>
</section>
