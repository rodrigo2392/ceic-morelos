---
import { site } from '../../data/site';
import ContactForm from '../ContactForm.tsx';
// Logo recortado (el original tiene mucho espacio transparente arriba/abajo).
const LOGO = '/img/ceic-white-trim.png';
const GRAIN =
  "data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22120%22 height=%22120%22><filter id=%22n%22><feTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%222%22/></filter><rect width=%22120%22 height=%22120%22 filter=%22url(%23n)%22/></svg>";

const DIRECCION = 'Cuauhtemotzín 25, Cuernavaca Centro, 62000 Cuernavaca, Morelos, México';
const mapsLink = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(DIRECCION)}`;
const mapEmbed = `https://maps.google.com/maps?q=${encodeURIComponent(DIRECCION)}&z=16&output=embed`;

const year = new Date().getFullYear();
---

<section id="contacto" data-theme="dark" style="position:relative;background:#0a0908;padding:clamp(80px,12vh,150px) clamp(24px,7vw,110px) 0;overflow:hidden">
  <div style={`position:absolute;inset:0;opacity:.08;pointer-events:none;background-image:url('${GRAIN}');background-size:200px`}></div>
  <div style="position:relative;z-index:2;max-width:1200px;margin:0 auto">
    <div data-reveal style="display:flex;align-items:baseline;gap:20px;margin-bottom:18px">
      <span style="font-family:'Bodoni Moda',serif;font-size:clamp(40px,6vw,84px);font-weight:400;color:rgba(244,239,230,.16);line-height:.8">08</span>
      <span style="font-family:'Space Mono',monospace;font-size:18px;letter-spacing:.22em;text-transform:uppercase;color:#d8a24a">Solicita informes</span>
    </div>
    <h2 data-reveal style="font-family:'Bodoni Moda',serif;font-weight:400;font-size:clamp(38px,7vw,96px);line-height:.98;margin:0 0 20px;max-width:900px">Tu primera película<br />empieza con un <em style="color:#d8a24a">mensaje</em></h2>
    <div class="ceic-contact" style="display:grid;grid-template-columns:1.15fr .85fr;gap:clamp(40px,7vw,90px);margin-top:56px;align-items:start">
      <ContactForm client:load />
      <div data-reveal style="display:flex;flex-direction:column;gap:30px">
        <div>
          <div style="font-family:'Space Mono',monospace;font-size:15px;letter-spacing:.2em;text-transform:uppercase;color:#d8a24a;margin-bottom:10px">Escuela</div>
          <p style="font-size:21px;line-height:1.6;margin:0 0 14px;color:rgba(244,239,230,.82);font-weight:300">Cuauhtemotzín #25<br />Cuernavaca Centro, C.P. 62000<br />Morelos, México</p>
          <a
            href={mapsLink}
            target="_blank"
            rel="noopener"
            class="ceic-link"
            style="font-family:'Space Mono',monospace;font-size:16px;letter-spacing:.14em;text-transform:uppercase;color:#d8a24a;border-bottom:1px solid rgba(216,162,74,.4);padding-bottom:3px">Cómo llegar →</a
          >
          <div class="ceic-map">
            <iframe
              src={mapEmbed}
              title="Ubicación del CEIC en Cuernavaca"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen></iframe>
          </div>
        </div>
        <div>
          <div style="font-family:'Space Mono',monospace;font-size:15px;letter-spacing:.2em;text-transform:uppercase;color:#d8a24a;margin-bottom:10px">WhatsApp</div>
          <a href={site.whatsapp.link} target="_blank" rel="noopener" class="ceic-link" style="font-size:21px;color:#f4efe6">{site.whatsapp.display}</a>
        </div>
        <div>
          <div style="font-family:'Space Mono',monospace;font-size:15px;letter-spacing:.2em;text-transform:uppercase;color:#d8a24a;margin-bottom:10px">Redes</div>
          <div style="display:flex;flex-direction:column;gap:8px">
            <a href={site.instagram.link} target="_blank" rel="noopener" class="ceic-link" style="font-size:21px;color:#f4efe6">Instagram — {site.instagram.handle}</a>
            <a href={site.facebook.link} target="_blank" rel="noopener" class="ceic-link" style="font-size:21px;color:#f4efe6">Facebook — {site.facebook.label}</a>
          </div>
        </div>
      </div>
    </div>

    <!-- final cartel -->
    <div data-reveal style="margin-top:clamp(70px,11vh,130px);border-top:1px solid rgba(244,239,230,.12);padding:clamp(40px,7vh,80px) 0;text-align:center">
      <img src={LOGO} alt="CEIC" style="display:block;height:auto;max-height:150px;width:auto;max-width:100%;margin:0 auto 30px;opacity:1" />
      <p style="font-family:'Bodoni Moda',serif;font-style:italic;font-size:clamp(24px,4vw,52px);line-height:1.1;margin:0 auto;max-width:900px">«El cine no se estudia:<br />se hace. Ven a hacerlo.»</p>
      <div style="font-family:'Space Mono',monospace;font-size:16px;letter-spacing:.3em;color:rgba(244,239,230,.4);margin-top:34px">CENTRO DE ESTUDIOS E INVESTIGACIÓN CINEMATOGRÁFICA · CUERNAVACA · MORELOS</div>
      <div style="font-family:'Space Mono',monospace;font-size:15px;letter-spacing:.2em;color:rgba(244,239,230,.28);margin-top:14px">© {year} CEIC · TODOS LOS DERECHOS RESERVADOS</div>
      <div class="ceic-credit" style="font-family:'Space Mono',monospace;font-size:12px;letter-spacing:.14em;color:rgba(244,239,230,.22);margin-top:40px;padding-bottom:30px">Hecho con <span style="color:#22d3ee">&#9829;</span> por <a href="https://rodrigomendez.dev" target="_blank" rel="noopener">Rodrigo Méndez</a></div>
    </div>
  </div>
</section>
