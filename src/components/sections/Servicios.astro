---
import { servicios } from '../../data/servicios';
---

<section id="servicios" data-theme="light" style="background:#efe9de;color:#1a1714;padding:clamp(80px,12vh,150px) clamp(24px,7vw,110px)">
  <div style="max-width:1400px;margin:0 auto">
    <div data-reveal style="display:flex;align-items:baseline;gap:20px;margin-bottom:18px">
      <span style="font-family:'Bodoni Moda',serif;font-size:clamp(40px,6vw,84px);font-weight:400;color:rgba(26,23,20,.14);line-height:.8">06</span>
      <span style="font-family:'Space Mono',monospace;font-size:18px;letter-spacing:.22em;text-transform:uppercase;color:#b07d2a">Casa productora</span>
    </div>
    <div data-reveal style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:20px;margin-bottom:52px">
      <h2 style="font-family:'Bodoni Moda',serif;font-weight:400;font-size:clamp(32px,5vw,66px);line-height:1;margin:0;max-width:820px">Servicios de producción, de la primera línea de guion al estreno</h2>
      <span class="ceic-serv-hint" style="font-family:'Space Mono',monospace;font-size:16px;letter-spacing:.16em;color:#b07d2a;white-space:nowrap">↔ Pasa el cursor para explorar</span>
    </div>

    <div data-reveal class="ceic-servicios">
      {
        servicios.map((s) => (
          <article class="ceic-serv-card" tabindex="0">
            <img src={s.img} alt={s.alt} loading="lazy" width="640" height="678" class="ceic-serv-img" />
            <div data-fallback class="ceic-serv-fallback">FOTO</div>
            <div class="ceic-serv-shade" />
            <div class="ceic-serv-vert">
              <span class="ceic-serv-code">{s.code}</span>
              <span class="ceic-serv-vtitle">{s.titulo}</span>
            </div>
            <div class="ceic-serv-body">
              <span class="ceic-serv-code">{s.code}</span>
              <h3>{s.titulo}</h3>
              <p>{s.desc}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
