---
import { cursos } from '../../data/cursos';
---

<section id="cursos" data-theme="light" style="background:#efe9de;color:#1a1714;padding:clamp(80px,12vh,150px) clamp(24px,7vw,110px)">
  <div style="max-width:1200px;margin:0 auto">
    <div data-reveal style="display:flex;align-items:baseline;gap:20px;margin-bottom:18px">
      <span style="font-family:'Bodoni Moda',serif;font-size:clamp(40px,6vw,84px);font-weight:400;color:rgba(26,23,20,.14);line-height:.8">02</span>
      <span style="font-family:'Space Mono',monospace;font-size:18px;letter-spacing:.22em;text-transform:uppercase;color:#b07d2a">Programa</span>
    </div>
    <div data-reveal style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:20px;margin-bottom:52px">
      <h2 style="font-family:'Bodoni Moda',serif;font-weight:400;font-size:clamp(32px,5vw,66px);line-height:1;margin:0">Cursos y diplomados</h2>
    </div>
    <div class="ceic-cursos" style="display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:rgba(26,23,20,.14);border:1px solid rgba(26,23,20,.14)">
      {
        cursos.map((c) => (
          <div data-reveal class="ceic-course" style="background:#efe9de;padding:clamp(30px,4vw,48px);transition:background .4s">
            <div style="display:flex;justify-content:space-between;font-family:'Space Mono',monospace;font-size:16px;letter-spacing:.14em;color:#b07d2a;margin-bottom:26px">
              <span>{c.code}</span>
              {c.meta && <span>{c.meta}</span>}
            </div>
            <h3 style="font-family:'Bodoni Moda',serif;font-weight:500;font-size:clamp(24px,2.6vw,34px);margin:0 0 14px;line-height:1.05">{c.titulo}</h3>
            <p style="font-size:20px;line-height:1.6;color:rgba(26,23,20,.66);margin:0 0 28px;font-weight:300">{c.desc}</p>
            <a href="#contacto" style="font-family:'Space Mono',monospace;font-size:17px;letter-spacing:.12em;text-transform:uppercase;color:#1a1714;border-bottom:1px solid #d8a24a;padding-bottom:4px">Más información →</a>
          </div>
        ))
      }
    </div>
  </div>
</section>
