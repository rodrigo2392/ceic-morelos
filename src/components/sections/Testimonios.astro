---
const stripeSm =
  'repeating-linear-gradient(135deg,#e3dccb,#e3dccb 5px,#d8d0bd 5px,#d8d0bd 10px)';
// Placeholder: 3 testimonios pendientes de recibir de CEIC (egresados).
const testimonios = [null, null, null];
---

<section id="testimonios" data-theme="light" style="background:#f4efe6;color:#1a1714;padding:clamp(80px,12vh,150px) clamp(24px,7vw,110px)">
  <div style="max-width:1200px;margin:0 auto">
    <div data-reveal style="display:flex;align-items:baseline;gap:20px;margin-bottom:18px">
      <span style="font-family:'Bodoni Moda',serif;font-size:clamp(40px,6vw,84px);font-weight:400;color:rgba(26,23,20,.14);line-height:.8">07</span>
      <span style="font-family:'Space Mono',monospace;font-size:18px;letter-spacing:.22em;text-transform:uppercase;color:#b07d2a">Egresados</span>
    </div>
    <div data-reveal style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:16px;margin-bottom:52px">
      <h2 style="font-family:'Bodoni Moda',serif;font-weight:400;font-size:clamp(32px,5vw,66px);line-height:1;margin:0">Lo que dicen</h2>
      <span style="font-family:'Space Mono',monospace;font-size:16px;letter-spacing:.16em;color:#b07d2a;border:1px solid rgba(176,125,42,.4);padding:7px 12px;border-radius:2px">◇ Contenido por completar</span>
    </div>
    <div class="ceic-testi" style="display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(16px,2.4vw,30px)">
      {
        testimonios.map(() => (
          <blockquote data-reveal style="margin:0;background:#efe9de;border:1px solid rgba(26,23,20,.12);padding:34px 30px;display:flex;flex-direction:column;gap:22px">
            <span style="font-family:'Bodoni Moda',serif;font-size:56px;line-height:.4;color:#d8a24a">“</span>
            <p style="font-family:'Bodoni Moda',serif;font-style:italic;font-size:25px;line-height:1.5;margin:0;color:rgba(26,23,20,.82)">Texto de testimonio pendiente. Aquí irá la cita del egresado sobre su paso por el CEIC.</p>
            <div style="display:flex;align-items:center;gap:14px;margin-top:auto">
              <div style={`width:46px;height:46px;border-radius:50%;background:${stripeSm}`}></div>
              <div>
                <div style="font-family:'Space Mono',monospace;font-size:17px;letter-spacing:.1em">Nombre del egresado</div>
                <div style="font-family:'Space Mono',monospace;font-size:15px;color:#b07d2a;margin-top:3px">Generación · Proyecto</div>
              </div>
            </div>
          </blockquote>
        ))
      }
    </div>
  </div>
</section>
