---
const GRAIN =
  "data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22120%22 height=%22120%22><filter id=%22n%22><feTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%222%22/></filter><rect width=%22120%22 height=%22120%22 filter=%22url(%23n)%22/></svg>";

const stats = [
  { n: '50', suf: '+', label: 'Festivales internacionales' },
  { n: '1', suf: '', label: 'Ariel · Mejor Documental' },
  { n: '20', suf: '+', label: 'Años de trayectoria' },
  { n: '4', suf: '', label: 'Maestros premiados' },
];

const NB = '  '; // doble espacio duro (como los &nbsp; del diseño)
const items = [
  'Ariel a Mejor Documental',
  'Selección Cannes',
  'Premio José Rovirosa · UNAM',
  'Premio Marcel Sisniega',
  'IMCINE',
  'Ambulante',
  'ESCAC Barcelona',
  'La Habana · Toronto',
];
const marquee = items.map((i) => `${i}${NB}·${NB}`).join('');
---

<section data-theme="dark" style="position:relative;background:#0d0c0b;padding:clamp(60px,9vh,96px) 0 clamp(50px,7vh,80px);overflow:hidden">
  <div style={`position:absolute;inset:0;opacity:.08;pointer-events:none;background-image:url('${GRAIN}');background-size:200px`}></div>
  <div class="ceic-stats" style="position:relative;z-index:2;max-width:1200px;margin:0 auto;padding:0 clamp(24px,7vw,110px);display:grid;grid-template-columns:repeat(4,1fr);gap:24px">
    {
      stats.map((s) => (
        <div data-reveal style="text-align:center;border-left:1px solid rgba(216,162,74,.28);padding-left:22px">
          <div style="font-family:'Bodoni Moda',serif;font-size:clamp(48px,6vw,80px);font-weight:400;line-height:1;color:#d8a24a">
            <span data-count={s.n}>0</span>{s.suf}
          </div>
          <div style="font-family:'Space Mono',monospace;font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:rgba(244,239,230,.62);margin-top:12px">{s.label}</div>
        </div>
      ))
    }
  </div>
  <div style="position:relative;z-index:2;margin-top:clamp(44px,6vh,70px);border-top:1px solid rgba(244,239,230,.1);border-bottom:1px solid rgba(244,239,230,.1);padding:22px 0;overflow:hidden;white-space:nowrap">
    <div style="display:inline-flex;animation:ceicMarquee 34s linear infinite">
      <span style="font-family:'Bodoni Moda',serif;font-style:italic;font-size:clamp(22px,3vw,40px);color:rgba(244,239,230,.78)">{marquee}</span>
      <span style="font-family:'Bodoni Moda',serif;font-style:italic;font-size:clamp(22px,3vw,40px);color:rgba(244,239,230,.78)">{marquee}</span>
    </div>
  </div>
</section>
